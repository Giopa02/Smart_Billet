<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.SeanceController"
            fitToWidth="true"
            style="-fx-background-color: #f8f9fa; -fx-background: #f8f9fa;">

    <VBox
          stylesheets="@../css/style.css"
          spacing="15" styleClass="content-area">

        <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

        <!-- TITRE + BOUTON AJOUTER -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="🎭 Gestion des Séances" styleClass="page-title" HBox.hgrow="ALWAYS"/>
            <Button text="+ Ajouter" styleClass="btn-add" onAction="#handleAjouter"/>
        </HBox>

        <!-- BARRE DE RECHERCHE + FILTRES -->
        <VBox spacing="8">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="🔍 Rechercher par événement..."
                           styleClass="text-field"
                           prefWidth="300"
                           onKeyReleased="#handleRecherche"/>
                <Button text="🔄 Réinitialiser" styleClass="btn-secondary" onAction="#handleReinitialiser"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="filtreSalle"
                          promptText="Salle"
                          styleClass="text-field"
                          prefWidth="180"
                          onAction="#handleFiltrer"/>
                <TextField fx:id="filtrePrixMin"
                           promptText="Prix min (€)"
                           styleClass="text-field"
                           prefWidth="110"
                           onKeyReleased="#handleFiltrer"/>
                <TextField fx:id="filtrePrixMax"
                           promptText="Prix max (€)"
                           styleClass="text-field"
                           prefWidth="110"
                           onKeyReleased="#handleFiltrer"/>
                <DatePicker fx:id="filtreDateDebut"
                            promptText="Date début"
                            styleClass="text-field"
                            prefWidth="150"
                            onAction="#handleFiltrer"/>
                <DatePicker fx:id="filtreDateFin"
                            promptText="Date fin"
                            styleClass="text-field"
                            prefWidth="150"
                            onAction="#handleFiltrer"/>
            </HBox>
        </VBox>

        <!-- TABLEAU -->
        <TableView fx:id="tableSeances" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="400">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colEvenement" text="Événement" prefWidth="200"/>
                <TableColumn fx:id="colSalle" text="Salle" prefWidth="150"/>
                <TableColumn fx:id="colDateHeure" text="Date et heure" prefWidth="160"/>
                <TableColumn fx:id="colPlacesRestantes" text="Places restantes" prefWidth="130"/>
                <TableColumn fx:id="colPrix" text="Prix (€)" prefWidth="80"/>
            </columns>
            <placeholder>
                <Label text="Aucune séance trouvée"/>
            </placeholder>
        </TableView>

        <!-- BOUTONS -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="✏️ Modifier" styleClass="btn-edit" onAction="#handleModifier"/>
            <Button text="🗑️ Supprimer" styleClass="btn-delete" onAction="#handleSupprimer"/>
        </HBox>

    </VBox>

</ScrollPane>