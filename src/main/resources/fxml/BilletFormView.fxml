<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.BilletFormController"
            fitToWidth="true"
            style="-fx-background-color: #f8f9fa; -fx-background: #f8f9fa;">

    <VBox
          stylesheets="@../css/style.css"
          spacing="15" styleClass="content-area"
          prefWidth="600">

        <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

        <Label text="Ajouter un billet" styleClass="page-title"/>

        <VBox spacing="12">

            <!-- Client -->
            <VBox spacing="5">
                <Label text="Client *" styleClass="form-label"/>
                <ComboBox fx:id="clientCombo" styleClass="text-field" prefWidth="400"/>
            </VBox>

            <!-- Séance -->
            <VBox spacing="5">
                <Label text="Séance *" styleClass="form-label"/>
                <ComboBox fx:id="seanceCombo" styleClass="text-field" prefWidth="400"/>
            </VBox>

            <!-- Prix -->
            <VBox spacing="5">
                <Label text="Prix (€) *" styleClass="form-label"/>
                <TextField fx:id="prixField" promptText="Ex: 35.00" styleClass="text-field"/>
            </VBox>

        </VBox>

        <!-- MESSAGE ERREUR -->
        <Label fx:id="errorLabel" styleClass="login-error" text="" visible="false"/>

        <!-- BOUTONS -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" styleClass="btn-secondary" onAction="#handleAnnuler"/>
            <Button text="Sauvegarder" styleClass="btn-add" onAction="#handleSauvegarder"/>
        </HBox>

    </VBox>

</ScrollPane>