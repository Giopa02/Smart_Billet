<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.ClientLoginController"
           stylesheets="@../css/style.css"
           styleClass="gradient-bg">

    <VBox alignment="CENTER" spacing="20" maxWidth="420">

        <!-- TITRE -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="🎟️ Smart Billet" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Espace Client" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>

        <!-- CARTE LOGIN -->
        <VBox styleClass="login-card" spacing="15">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <Label text="Connexion" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

            <VBox spacing="5">
                <Label text="Email" styleClass="form-label"/>
                <TextField fx:id="emailField" promptText="exemple@email.com" styleClass="login-field"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Mot de passe" styleClass="form-label"/>
                <PasswordField fx:id="passwordField" promptText="Votre mot de passe" styleClass="login-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="login-error" text="" visible="false"/>

            <Button text="Se connecter" styleClass="btn-login"
                    maxWidth="Infinity" onAction="#handleLogin"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Pas encore de compte ?" style="-fx-text-fill: #888888;"/>
                <Button text="S'inscrire" styleClass="btn-secondary"
                        onAction="#handleAllerInscription"/>
            </HBox>

            <Button text="← Retour à l'accueil" styleClass="btn-secondary"
                    maxWidth="Infinity" onAction="#handleRetour"/>

        </VBox>

    </VBox>

</StackPane>