<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ClientEvenementDetailController"
            fitToWidth="true"
            style="-fx-background-color: #f8f9fa; -fx-background: #f8f9fa;">

    <VBox stylesheets="@../css/style.css"
          spacing="20"
          style="-fx-background-color: #f8f9fa;">

        <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

        <!-- BOUTON RETOUR -->
        <Button text="← Retour aux événements" styleClass="btn-secondary"
                onAction="#handleRetour"/>

        <!-- HEADER : affiche + infos principales -->
        <HBox spacing="25" alignment="TOP_LEFT">

            <!-- Affiche -->
            <ImageView fx:id="afficheImage"
                       fitWidth="250" fitHeight="320"
                       preserveRatio="true"
                       style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);"/>

            <!-- Infos -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label fx:id="titreLabel"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333333;"
                       wrapText="true"/>
                <Label fx:id="descriptionCourteLabel"
                       style="-fx-font-size: 14px; -fx-text-fill: #666666;"
                       wrapText="true"/>

                <HBox spacing="20">
                    <Label fx:id="langueLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                    <Label fx:id="dureeLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                    <Label fx:id="ageMinLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                </HBox>

                <Label fx:id="prixLabel"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #5c6bc0;"/>

                <Label fx:id="categoriesLabel"
                       style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"
                       wrapText="true"/>
            </VBox>
        </HBox>

        <!-- DESCRIPTION LONGUE -->
        <VBox spacing="8"
              style="-fx-background-color: white; -fx-background-radius: 10px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="📖 Description"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <Label fx:id="descriptionLongueLabel"
                   style="-fx-font-size: 13px; -fx-text-fill: #555555;"
                   wrapText="true"/>
        </VBox>

        <!-- SÉANCES DISPONIBLES -->
        <VBox spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 10px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="📅 Séances disponibles"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <VBox fx:id="seancesContainer" spacing="10"/>
        </VBox>

    </VBox>

</ScrollPane>