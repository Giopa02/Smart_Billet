<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ClientDashboardController"
            stylesheets="@../css/style.css">

    <!-- NAVBAR HAUT -->
    <top>
        <HBox styleClass="sidebar" spacing="20" alignment="CENTER_LEFT">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>

            <Label text="🎟️ Smart Billet"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <Button text="🎭 Événements" styleClass="sidebar-btn"
                    fx:id="btnEvenements" onAction="#showEvenements"/>
            <Button text="🎫 Mes billets" styleClass="sidebar-btn"
                    fx:id="btnMesBillets" onAction="#showMesBillets"/>
            <Button text="👤 Mon compte" styleClass="sidebar-btn"
                    fx:id="btnMonCompte" onAction="#showMonCompte"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="clientNomLabel"
                   style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;"/>
            <Button text="🚪 Déconnexion" styleClass="sidebar-btn"
                    style="-fx-text-fill: rgba(255,100,100,0.9);"
                    onAction="#handleDeconnexion"/>
        </HBox>
    </top>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <StackPane fx:id="contentArea">
            <VBox alignment="CENTER" spacing="15">
                <Label text="👋 Bienvenue sur Smart Billet !"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #5c6bc0;"/>
                <Label text="Découvrez nos événements et réservez vos billets"
                       style="-fx-font-size: 14px; -fx-text-fill: #888888;"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>