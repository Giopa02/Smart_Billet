<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ClientInscriptionController"
            fitToWidth="true"
            style="-fx-background-color: #f0f4ff; -fx-background: #f0f4ff;">

    <VBox stylesheets="@../css/style.css"
          spacing="20"
          alignment="CENTER"
          style="-fx-background-color: #f0f4ff;"
          prefWidth="600">

        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- TITRE -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="🎟️ Smart Billet" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #5c6bc0;"/>
            <Label text="Créer un compte" style="-fx-font-size: 16px; -fx-text-fill: #888888;"/>
        </VBox>

        <!-- CARTE FORMULAIRE -->
        <VBox styleClass="card" spacing="15" maxWidth="450">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <!-- Nom -->
            <VBox spacing="5">
                <Label text="Nom complet *" styleClass="form-label"/>
                <TextField fx:id="nomField" promptText="Prénom Nom" styleClass="text-field"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="5">
                <Label text="Email *" styleClass="form-label"/>
                <TextField fx:id="emailField" promptText="exemple@email.com" styleClass="text-field"/>
            </VBox>

            <!-- Mot de passe -->
            <VBox spacing="5">
                <Label text="Mot de passe *" styleClass="form-label"/>
                <PasswordField fx:id="passwordField" promptText="Minimum 6 caractères" styleClass="text-field"/>
            </VBox>

            <!-- Confirmation mot de passe -->
            <VBox spacing="5">
                <Label text="Confirmer le mot de passe *" styleClass="form-label"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Répétez le mot de passe" styleClass="text-field"/>
            </VBox>

            <!-- Téléphone -->
            <VBox spacing="5">
                <Label text="Téléphone" styleClass="form-label"/>
                <TextField fx:id="telephoneField" promptText="0612345678" styleClass="text-field"/>
            </VBox>

            <!-- Adresse -->
            <VBox spacing="5">
                <Label text="Adresse" styleClass="form-label"/>
                <TextField fx:id="adresseField" promptText="Adresse complète" styleClass="text-field"/>
            </VBox>

            <!-- Date de naissance -->
            <VBox spacing="5">
                <Label text="Date de naissance" styleClass="form-label"/>
                <DatePicker fx:id="dateNaissancePicker" styleClass="text-field"/>
            </VBox>

            <!-- Message erreur -->
            <Label fx:id="errorLabel" styleClass="login-error" text="" visible="false"/>

            <!-- Bouton inscription -->
            <Button text="Créer mon compte" styleClass="btn-add"
                    maxWidth="Infinity" onAction="#handleInscription"/>

            <!-- Lien connexion -->
            <HBox alignment="CENTER" spacing="5">
                <Label text="Déjà un compte ?" style="-fx-text-fill: #888888;"/>
                <Button text="Se connecter" styleClass="btn-secondary"
                        onAction="#handleAllerConnexion"/>
            </HBox>

        </VBox>

    </VBox>

</ScrollPane>